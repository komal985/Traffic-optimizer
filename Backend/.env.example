PORT=3000
# Local MongoDB:
# MONGODB_URI=mongodb://localhost:27017/traffic_optimizer
#
# MongoDB Atlas (recommended cloud setup):
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/traffic_optimizer?retryWrites=true&w=majority&appName=Cluster0
MONGODB_FALLBACK_ENABLED=true
MONGODB_FALLBACK_DB_PATH=./.mongo-data
JWT_SECRET=change-me
